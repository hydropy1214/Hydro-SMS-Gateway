# ─── HYDROPY Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in the values before starting the server.
# On Replit these are managed via Secrets — do NOT commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. On Ubuntu: create a DB and paste the URL here.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/hydropy

# ── Server ────────────────────────────────────────────────────────────────────
# Port the API server listens on. Defaults to 8080 if not set.
PORT=8080

# ── Gateway App QR Code ───────────────────────────────────────────────────────
# Public URL of this server — used to build QR codes for the Gateway app.
# On Replit this is set automatically. On Ubuntu, set to your public IP or domain.
# Examples:
#   http://192.168.1.100:8080   (LAN, for testing)
#   https://yourserver.com      (production with HTTPS)
SERVER_URL=http://YOUR_SERVER_IP:8080

# ── Session ───────────────────────────────────────────────────────────────────
# Secret used for signing session tokens. Generate with: openssl rand -hex 32
SESSION_SECRET=change_this_to_a_random_string
